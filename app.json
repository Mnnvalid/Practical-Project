{
   "expo": {
      "name": "stamponit",
      "slug": "stamponit",
      "version": "1.0.0",
      "orientation": "portrait",
      "platforms": ["ios", "android", "web"],

      "ios": {
         "infoPlist": {
            "NSLocationWhenInUseUsageDescription": "StampOnIt needs your location to allow park check-ins."
         }
      },

      "android": {
         "permissions": ["ACCESS_FINE_LOCATION"]
      }
   }
}
